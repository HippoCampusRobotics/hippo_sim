<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="hippocampus">
    <xacro:include filename="$(find hippo_sim)/urdf/hippo2_params.xacro" />
    <xacro:include filename="$(find hippo_sim)/urdf/thruster_macro.xacro" />
    <gazebo>
        <static>false</static>
    </gazebo>
    <link name="base_link">
        <inertial>
            <mass value="${base_mass}" />
            <inertia ixx="${ixx}" ixy="0.0" ixz="0.0" iyy="${iyy}" iyz="0.0" izz="${izz}" />
        </inertial>
        <visual>
            <geometry>
                <mesh filename="$(find hippo_sim)/meshes/hippo3_tube.dae" />
            </geometry>
        </visual>
    </link>

    <link name="flange_link">
        <inertial>
            <mass value="1e-5" />
            <inertia ixx="1e-5" ixy="0.0" ixz="0.0" iyy="1e-5" iyz="0.0" izz="1e-5" />
        </inertial>
        <visual>
            <geometry>
                <mesh filename="$(find hippo_sim)/meshes/hippo3_flange.dae" />
            </geometry>
        </visual>
    </link>
    <joint name="flange_joint" type="fixed">
        <parent link="base_link" />
        <child link="flange_link" />
    </joint>
    <link name="dome_link">
        <inertial>
            <mass value="1e-5" />
            <inertia ixx="1e-5" ixy="0.0" ixz="0.0" iyy="1e-5" iyz="0.0" izz="1e-5" />
        </inertial>
        <visual>
            <geometry>
                <mesh filename="$(find hippo_sim)/meshes/hippo3_dome.dae" />
            </geometry>
        </visual>
    </link>
    <joint name="dome_joint" type="fixed">
        <parent link="base_link" />
        <child link="dome_link" />
    </joint>

    <gazebo reference="flange_joint">
        <preserveFixedJoint>true</preserveFixedJoint>
    </gazebo>

    <gazebo reference="dome_joint">
        <preserveFixedJoint>true</preserveFixedJoint>
    </gazebo>

    <gazebo reference="base_link">
        <sensor name="imu_sensor" type="imu">
            <always_on>1</always_on>
            <visualize>true</visualize>
            <topic>imu_topic</topic>
        </sensor>
        <visual>
            <material>
                <ambient>0.5 0.5 0.9 0.2</ambient>
                <diffuse>0.5 0.5 0.9 0.5</diffuse>
                <specular>1 1 1 1</specular>
            </material>
        </visual>
    </gazebo>

    <gazebo reference="flange_link">
        <visual>
            <material>
                <ambient>1 1 1 1</ambient>
                <diffuse>1 1 1 1</diffuse>
                <specular>1 1 1 1</specular>
                <pbr>
                    <metal>
                        <metalness>1</metalness>
                        <roughness>0.5</roughness>
                        <environment_map>$(find hippo_sim)/textures/env_map.dds</environment_map>
                        <albedo_map>$(find hippo_sim)/textures/dark_grey.png</albedo_map>
                    </metal>
                </pbr>
            </material>
        </visual>
    </gazebo>

    <gazebo reference="dome_link">
        <visual>
            <material>
                <ambient>0.5 0.5 0.9 0.2</ambient>
                <diffuse>0.5 0.5 0.9 0.5</diffuse>
                <specular>1 1 1 1</specular>
            </material>
        </visual>
    </gazebo>

    <xacro:thruster parent="base_link" suffix="port_top" xyz="0 -${thruster_r / 2**0.5} ${thruster_r / 2**0.5}" axis="1 0 0" cw="true" color="red" number="0" />
    <xacro:thruster parent="base_link" suffix="starboard_top" xyz="0 ${thruster_r / 2**0.5} ${thruster_r / 2**0.5}" axis="1 0 0" cw="false" color="green" number="1" />
    <xacro:thruster parent="base_link" suffix="starboard_bot" xyz="0 ${thruster_r / 2**0.5} -${thruster_r / 2**0.5}" axis="1 0 0" cw="true" color="grey" number="2" />
    <xacro:thruster parent="base_link" suffix="port_bot" xyz="0 -${thruster_r / 2**0.5} -${thruster_r / 2**0.5}" axis="1 0 0" cw="false" color="grey" number="3" />

    <gazebo>
        <plugin filename="BuoyancyPlugin" name="ignition::gazebo::systems::BuoyancyPlugin">
            <buoyancy>
                <link_name>base_link</link_name>
                <origin>0 0 0.002</origin>
                <force_added>0</force_added>
                <compensation>1.01</compensation>
                <height_scale_limit>0.1</height_scale_limit>
            </buoyancy>
        </plugin>

        <plugin filename="HydrodynamicsPlugin" name="ignition::gazebo::systems::HydrodynamicsPlugin">
            <hydrodynamics>
                <link>base_link</link>
                <added_mass_linear>${added_mass_linear}</added_mass_linear>
                <added_mass_angular>${added_mass_angular}</added_mass_angular>
                <damping_linear>${damping_linear}</damping_linear>
                <damping_angular>${damping_angular}</damping_angular>
            </hydrodynamics>
        </plugin>

    </gazebo>
</robot>
