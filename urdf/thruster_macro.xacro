<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="thruster" params="suffix parent xyz axis cw">
        <xacro:include filename="$(find hippo_sim)/urdf/thruster_params.xacro" />

        <xacro:property name="mount_link" value="${suffix}_thruster_mount_link" />
        <xacro:property name="mount_joint" value="${suffix}_thruster_mount_joint" />
        <xacro:property name="hull_link" value="${suffix}_thruster_hull_link" />
        <xacro:property name="hull_joint" value="${suffix}_thruster_hull_joint" />
        <xacro:property name="propeller_link" value="${suffix}_thruster_propeller_link" />
        <xacro:property name="propeller_joint" value="${suffix}_thruster_propeller_joint" />


        <link name="${mount_link}">
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertial>
                <mass value="${thruster_mass}" />
                <inertia ixx="${thruster_ixx}" ixy="0.0" ixz="0.0" iyy="${thruster_iyy}" iyz="0.0" izz="${thruster_izz}" />
            </inertial>
            <visual>
                <geometry>
                    <mesh filename="$(find hippo_sim)/meshes/hippo3_motor_mount.dae" />
                </geometry>
            </visual>
        </link>
        <gazebo reference="${mount_link}">
            <visual>
                <material>
    
                    <ambient>1 1 1 1</ambient>
                    <diffuse>1 1 1 1</diffuse>
                    <specular>1 1 1 1</specular>
                    <pbr>
                        <metal>
                            <metalness>1</metalness>
                            <roughness>0.5</roughness>
                            <environment_map>$(find hippo_sim)/textures/env_map.dds</environment_map>
                            <albedo_map>$(find hippo_sim)/textures/grey.png</albedo_map>
                        </metal>
                    </pbr>
                </material>
            </visual>
        </gazebo>
        <joint name="${mount_joint}" type="continuous">
            <axis xyz="${axis}" />
            <origin xyz="${xyz}" />
            <parent link="${parent}" />
            <child link="${mount_link}" />
        </joint>

        <link name="${hull_link}">
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertial>
                <mass value="${thruster_mass}" />
                <inertia ixx="${thruster_ixx}" ixy="0.0" ixz="0.0" iyy="${thruster_iyy}" iyz="0.0" izz="${thruster_izz}" />
            </inertial>
            <visual>
                <geometry>
                    <mesh filename="$(find hippo_sim)/meshes/hippo3_motor_hull.dae" />
                </geometry>
            </visual>
        </link>
        <gazebo reference="${hull_link}">
            <visual>
                <material>
    
                    <ambient>1 1 1 1</ambient>
                    <diffuse>1 1 1 1</diffuse>
                    <specular>1 1 1 1</specular>
                    <pbr>
                        <metal>
                            <metalness>1</metalness>
                            <roughness>0.5</roughness>
                            <environment_map>$(find hippo_sim)/textures/env_map.dds</environment_map>
                            <albedo_map>$(find hippo_sim)/textures/hippocampus_text.png</albedo_map>
                        </metal>
                    </pbr>
                </material>
            </visual>
        </gazebo>
        <joint name="${hull_joint}" type="continuous">
            <axis xyz="${axis}" />
            <origin xyz="${xyz}" />
            <parent link="${parent}" />
            <child link="${hull_link}" />
        </joint>

        <link name="${propeller_link}">
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertial>
                <mass value="${thruster_mass}" />
                <inertia ixx="${thruster_ixx}" ixy="0.0" ixz="0.0" iyy="${thruster_iyy}" iyz="0.0" izz="${thruster_izz}" />
            </inertial>
            <visual>
                <geometry>
                    <mesh filename="$(find hippo_sim)/meshes/propeller.dae" />
                </geometry>
            </visual>
        </link>
        <gazebo reference="${propeller_link}">
            <visual>
                <material>
    
                    <ambient>1 1 1 1</ambient>
                    <diffuse>1 1 1 1</diffuse>
                    <specular>1 1 1 1</specular>
                    <pbr>
                        <metal>
                            <metalness>1</metalness>
                            <roughness>0.3</roughness>
                            <environment_map>$(find hippo_sim)/textures/env_map.dds</environment_map>
                            <albedo_map>$(find hippo_sim)/textures/red.png</albedo_map>
                        </metal>
                    </pbr>
                </material>
            </visual>
        </gazebo>
        <joint name="${propeller_joint}" type="continuous">
            <axis xyz="${axis}" />
            <origin xyz="${xyz}" />
            <parent link="${parent}" />
            <child link="${propeller_link}" />
        </joint>
    </xacro:macro>
</robot>
